<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.passwordmanager.controllers.RegisterController"
           styleClass="screen-bg">

    <ScrollPane fitToWidth="true" styleClass="transparent-scroll" StackPane.alignment="CENTER">
        <VBox alignment="CENTER" spacing="0" maxWidth="420">
            <padding><Insets top="40" right="48" bottom="40" left="48"/></padding>

            <!-- Logo area -->
            <VBox alignment="CENTER" spacing="8" style="-fx-padding: 0 0 24 0;">
                <Label text="🔐" styleClass="logo-icon"/>
                <Label text="Create Account" styleClass="app-name"/>
                <Label text="Set up your secure vault." styleClass="app-tagline"/>
            </VBox>

            <!-- Form card -->
            <VBox styleClass="card" spacing="18">
                <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

                <!-- Username -->
                <VBox spacing="6">
                    <Label text="Username" styleClass="field-label"/>
                    <TextField fx:id="usernameField" styleClass="text-input" promptText="Choose a username"/>
                </VBox>

                <!-- Master Password -->
                <VBox spacing="6">
                    <Label text="Master Password" styleClass="field-label"/>
                    <PasswordField fx:id="passwordField" styleClass="text-input"
                                  promptText="Choose a strong master password"/>
                    <!-- Strength meter -->
                    <HBox fx:id="strengthRow" spacing="10" alignment="CENTER_LEFT">
                        <Region fx:id="strengthBar" minHeight="6" prefHeight="6"
                                styleClass="strength-bar" minWidth="60"/>
                        <Label fx:id="strengthLabel" styleClass="strength-text"/>
                    </HBox>
                </VBox>

                <!-- Confirm Password -->
                <VBox spacing="6">
                    <Label text="Confirm Password" styleClass="field-label"/>
                    <PasswordField fx:id="confirmPasswordField" styleClass="text-input"
                                  promptText="Repeat your master password"/>
                </VBox>

                <!-- Warning -->
                <VBox styleClass="warning-box" spacing="4">
                    <Label text="⚠  Important Security Notice" styleClass="warning-title"/>
                    <Label wrapText="true" styleClass="warning-body"
                           text="Your master password cannot be recovered if lost. Write it down and store it in a safe place."/>
                </VBox>

                <!-- Error -->
                <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

                <!-- Register button -->
                <Button fx:id="registerBtn" text="Create Account" styleClass="btn-primary"
                        maxWidth="Infinity" onAction="#handleRegister"/>
            </VBox>

            <!-- Login link -->
            <HBox alignment="CENTER" spacing="4" style="-fx-padding: 16 0 0 0;">
                <Label text="Already have an account?" styleClass="hint-text"/>
                <Hyperlink fx:id="loginLink" text="Sign in" styleClass="link"
                           onAction="#handleBackToLogin"/>
            </HBox>
        </VBox>
    </ScrollPane>
</StackPane>
