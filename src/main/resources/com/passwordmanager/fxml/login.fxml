<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.passwordmanager.controllers.LoginController"
           styleClass="screen-bg">

    <VBox alignment="CENTER" spacing="0" maxWidth="420" StackPane.alignment="CENTER">
        <padding><Insets top="48" right="48" bottom="48" left="48"/></padding>

        <!-- Logo area -->
        <VBox alignment="CENTER" spacing="8" style="-fx-padding: 0 0 32 0;">
            <Label text="🔐" styleClass="logo-icon"/>
            <Label text="Vault" styleClass="app-name"/>
            <Label text="Your passwords, secured." styleClass="app-tagline"/>
        </VBox>

        <!-- Form card -->
        <VBox styleClass="card" spacing="20">
            <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

            <Label text="Sign In" styleClass="card-title"/>

            <!-- Username -->
            <VBox spacing="6">
                <Label text="Username" styleClass="field-label"/>
                <TextField fx:id="usernameField" styleClass="text-input" promptText="Enter your username"/>
            </VBox>

            <!-- Password -->
            <VBox spacing="6">
                <Label text="Master Password" styleClass="field-label"/>
                <PasswordField fx:id="passwordField" styleClass="text-input" promptText="Enter your master password"/>
            </VBox>

            <!-- Error -->
            <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

            <!-- Lockout box -->
            <VBox fx:id="lockoutBox" styleClass="lockout-box" spacing="4">
                <Label text="⚠ Account Locked" styleClass="lockout-title"/>
                <Label fx:id="lockoutLabel" styleClass="lockout-message" wrapText="true"/>
            </VBox>

            <!-- Attempts -->
            <Label fx:id="attemptsLabel" styleClass="warning-label" wrapText="true"/>

            <!-- Login button -->
            <Button fx:id="loginBtn" text="Unlock Vault" styleClass="btn-primary"
                    maxWidth="Infinity" onAction="#handleLogin"/>
        </VBox>

        <!-- Create account link -->
        <HBox alignment="CENTER" spacing="4" style="-fx-padding: 20 0 0 0;">
            <Label text="Don't have an account?" styleClass="hint-text"/>
            <Hyperlink fx:id="createAccountLink" text="Create one" styleClass="link"
                       onAction="#handleCreateAccount"/>
        </HBox>
    </VBox>
</StackPane>
